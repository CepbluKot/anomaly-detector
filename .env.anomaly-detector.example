# ClickHouse connection for writing anomaly results
# Copy this file to .env.anomaly-detector and fill in real values.

ANOMALY_CH_HOST=localhost
ANOMALY_CH_PORT=8123
ANOMALY_CH_USER=default
ANOMALY_CH_PASSWORD=
ANOMALY_CH_DATABASE=default

# Optional: set log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
